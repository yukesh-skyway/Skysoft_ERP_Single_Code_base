{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": false,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@shadcn-scheduler/core": ["packages/core/src"],
      "@shadcn-scheduler/shell": ["packages/shell/src"],
      "@shadcn-scheduler/grid-engine": ["packages/grid-engine/src"],
      "@shadcn-scheduler/view-*": ["packages/view-*/src"],
      "@shadcn-scheduler/plugin-*": ["packages/plugin-*/src"],
      "@shadcn-scheduler/preset-*": ["packages/preset-*/src"]
    }
  },
  "files": [],
  "include": [],
  "exclude": ["node_modules", "**/dist", "**/build"]
}